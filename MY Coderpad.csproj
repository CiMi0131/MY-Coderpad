    <Authors>CiMi131's Lab</Authors>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="coderPad.ico" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\..\Downloads\coderPad.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>