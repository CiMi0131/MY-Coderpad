    <RootNamespace>MY_Coderpad</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>coderPad.ico</ApplicationIcon>
    <Version>26.0</Version>
    <Company>CiMi131's Lab</Company>
    <PackageIcon>coderPad.png</PackageIcon>
